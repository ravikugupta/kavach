# Copy this file to .env (or export these as shell env vars) to enable
# optional LLM-enhanced responses. Both are optional -- the app works
# fully offline without either set.

# Option A: Local Ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1:1.5b

# Option B: Anthropic Claude API
# ANTHROPIC_API_KEY=sk-ant-...
